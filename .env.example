# ── Banco de Dados ───────────────────────────────────────────────────────────
# SQLite (padrão local):
DATABASE_URL=sqlite:////data/sorteios.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/sorteios

# ── Autenticação Admin ────────────────────────────────────────────────────────
ADMIN_PASSWORD=troque-por-senha-forte
COOKIE_SECRET=gere-uma-string-aleatoria-de-64-chars-ou-mais-aqui

# ── URL Base (para links nos e-mails e compartilhamento) ─────────────────────
BASE_URL=http://localhost:8000
# Produção: BASE_URL=https://seudominio.com

# ── E-mail SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua-app-password-gmail
SMTP_FROM=noreply@seudominio.com
SMTP_FROM_NAME=Sorteios
ADMIN_EMAIL=admin@seudominio.com

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/data/backups
