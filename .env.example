# ── Banco de Dados ───────────────────────────────────────────────────────────
# SQLite (padrão local):
DATABASE_URL=sqlite:////data/sorteios.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/sorteios

# ── Autenticação Admin ────────────────────────────────────────────────────────
ADMIN_PASSWORD=troque-por-senha-forte
COOKIE_SECRET=gere-uma-string-aleatoria-de-64-chars-ou-mais-aqui

# ── URL Base (para links nos e-mails e compartilhamento) ─────────────────────
BASE_URL=http://localhost:8000
# Produção: BASE_URL=https://seudominio.com

# ── E-mail SMTP ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua-app-password-gmail
SMTP_FROM=noreply@seudominio.com
SMTP_FROM_NAME=Sorteios
ADMIN_EMAIL=admin@seudominio.com

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/data/backups

# Upload por link compartilhado (sem API Google)
# Exemplo: webhook n8n / Apps Script Web App / URL assinada de storage
# BACKUP_SHARED_UPLOAD_URL=https://seu-endpoint/upload
# BACKUP_SHARED_UPLOAD_METHOD=PUT
# BACKUP_SHARED_BEARER_TOKEN=seu-token-opcional

# Modo legado: Google Drive API (opcional)
# GDRIVE_CREDENTIALS_JSON=/data/gdrive-credentials.json
# GDRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456
